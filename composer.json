{
    "name": "directorytree/privacy-filter-classifier",
    "description": "Framework agnostic PHP classifier for privacy-filter.cpp binaries.",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "DirectoryTree\\PrivacyFilterClassifier\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DirectoryTree\\PrivacyFilterClassifier\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    }
}
